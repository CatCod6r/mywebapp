[Unit]
Description=My Web App Service
After=network.target postgresql.service

[Service]
User=app
Group=app
WorkingDirectory=/home/student/mywebapp

ExecStartPre=/usr/bin/python3 /home/student/mywebapp/migrate.py
ExecStart=/usr/bin/python3 /home/student/mywebapp/app.py

Restart=always

[Install]
WantedBy=multi-user.target
